---
// Get current year for copyright statement
const currentYear = new Date().getFullYear();
import LogoHorizontal from "./svg/LogoHorizontal.astro";
---

<footer aria-labelledby="footer-heading" class="bg-gray-900 text-white">
  <h2 id="footer-heading" class="sr-only">Footer</h2>

  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between md:flex-row">
      <!-- Logo -->
      <div class="mb-6 md:mb-0">
        <a
          href="/"
          class="inline-block"
          aria-label="Confederation College Home"
        >
          <LogoHorizontal
            primaryColor="#ffffff"
            secondaryColor="#ffffff"
            class="h-12 w-auto"
            width="200"
            height="48"
          />
        </a>
      </div>

      <!-- Contact info -->
      <address
        class="text-small mb-6 text-center text-gray-300 not-italic md:mb-0 md:text-right"
      >
        <p>Confederation College</p>
        <p>Thunder Bay, Ontario</p>
        <!-- <p class="mt-2">
          <a href="tel:+18076731401" class="hover:text-white transition"
            >807-673-1401</a
          >
        </p> -->
      </address>
    </div>

    <!-- Copyright -->
    <div class="mt-8 border-t border-gray-700 pt-6">
      <p class="text-small text-center text-gray-300">
        &copy; {currentYear} Confederation College. All rights reserved.
      </p>
    </div>
  </div>
</footer>
